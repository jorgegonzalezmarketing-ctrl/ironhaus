# ==========================================================================
# IRONHAUS — Variables de entorno (copiar a .env.local y completar)
# NUNCA subir .env.local al repositorio. Estas claves son secretas.
# ==========================================================================

# URL pública del sitio (usada en redirecciones de pago y webhooks)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --------------------------------------------------------------------------
# Mercado Pago  (https://www.mercadopago.cl/developers)
# Sin estas variables, el checkout opera en MODO DEMO (pago simulado).
# --------------------------------------------------------------------------
MP_ACCESS_TOKEN=""              # Access Token (TEST-... o APP_USR-...)
NEXT_PUBLIC_MP_PUBLIC_KEY=""    # Public Key (para Checkout API en el cliente)

# --------------------------------------------------------------------------
# WebPay Plus / Transbank  (https://www.transbankdevelopers.cl)
# Sin estas variables, el checkout opera en MODO DEMO (pago simulado).
# --------------------------------------------------------------------------
WEBPAY_COMMERCE_CODE=""         # Código de comercio
WEBPAY_API_KEY=""               # API Key Secret
WEBPAY_ENV="integration"        # "integration" (sandbox) | "production"

# --------------------------------------------------------------------------
# Base de datos PostgreSQL (Supabase). Prisma usa el pooler en runtime
# y la conexión directa para migraciones. Contraseña URL-encoded.
# --------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --------------------------------------------------------------------------
# Panel de administración
# --------------------------------------------------------------------------
ADMIN_SESSION_SECRET="cadena-larga-y-aleatoria"   # firma de la sesión admin

# Almacenamiento de fotos (Supabase Storage) — para subir imágenes desde el panel
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role-key-de-supabase"
# Opcionales: credenciales del admin que crea el seed (npm run db:seed)
# ADMIN_EMAIL="holajenny@ironhaus.cl"
# ADMIN_PASSWORD="cambiar-esto"
# ADMIN_NAME="Jenny"

# --------------------------------------------------------------------------
# Almacenamiento de imágenes (preparado para fase 2)
# --------------------------------------------------------------------------
